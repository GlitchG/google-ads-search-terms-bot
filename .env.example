# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# ── Google Ads ──────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# Filled automatically by: python get_refresh_token.py
GOOGLE_ADS_REFRESH_TOKEN=
# Manager (MCC) account ID, digits only, no dashes
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# Client account ID, digits only, no dashes
GOOGLE_ADS_CUSTOMER_ID=

# ── Account specifics ───────────────────────────────────────
ACCOUNT_NAME=Account
ACCOUNT_TZ=America/New_York
# Shared negative keyword list applied across the account
NEGATIVE_LIST_NAME=negatives
# sharedSetId from the negative-list URL (sharedSetId=...) in the Google Ads UI
NEGATIVE_LIST_SHARED_SET_ID=

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Chat ID (negative for groups). Get it with: python get_chat_id.py
TELEGRAM_CHAT_ID=

# ── Run / schedule ──────────────────────────────────────────
LOOKBACK_DAYS=4
APPROVAL_TIMEOUT_HOURS=12
SCHEDULE_TZ=Europe/Lisbon
SCHEDULE_DAYS=tue,fri
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0

# NOTE: edit the classification rules for your vertical in src/rules.py
